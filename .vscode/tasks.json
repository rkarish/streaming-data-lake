            "command": "pkill -f 'kubectl port-forward.*-n flink' 2>/dev/null || true; kubectl port-forward svc/flink-session-rest -n flink 8081:8081 &>/dev/null & echo 'Port-forwards running:' && echo '    - Flink Session: http://localhost:8081' && echo '' && echo 'Press Ctrl+C to stop.' && wait",

{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "reload-system (application-mode)",
            "type": "shell",
            "command": "bash k8s/scripts/teardown-k8s.sh; docker compose down && docker compose up -d && FLINK_MODE=application bash scripts/setup.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "reload-system (session-mode)",
